# ============================================================
# QlockCare Backend — Environment Configuration
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ----- Runtime -----
APP_ENV=development                  # development | staging | production | test
APP_NAME=qlockcare-backend
APP_VERSION=0.1.0
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console

# ----- HTTP Server -----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
REQUEST_BODY_SIZE_LIMIT=2mb

# ----- Database (Supabase Postgres) -----
# DATABASE_URL is the DIRECT connection (Alembic migrations only).
# Port 5432 in cloud Supabase, 54322 in local `supabase start`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres
# DATABASE_POOL_URL is the Supavisor-pooled connection (app runtime).
# Port 6543 in cloud Supabase. Falls back to DATABASE_URL in local dev if not set.
DATABASE_POOL_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres
DATABASE_POOL_SIZE=25
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_ECHO=false                  # true for SQL logging in dev only

# ----- Supabase -----
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_JWT_SECRET=replace_me_32_chars_minimum_secret_key
SUPABASE_STORAGE_BUCKET_QUALIFICATIONS=qualifications

# ----- Auth / JWT -----
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=qlockcare
JWT_AUDIENCE=qlockcare-api
PASSWORD_HASH_ALGORITHM=argon2       # argon2 | bcrypt
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# ----- Email Verification (OTP) — ADR-0016 -----
OTP_LENGTH=4
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RESEND_MAX_PER_HOUR=5
OTP_RESEND_MAX_PER_DAY=20
INVITATION_TOKEN_EXPIRY_DAYS=7

# ----- Email (SMTP) -----
SMTP_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025                       # MailHog default in dev
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@qlockcare.local
SMTP_FROM_NAME=QlockCare
SMTP_USE_TLS=false                   # true in production

# ----- SMS (Twilio) - Phase 2 -----
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----- File Storage (ADR-0018) -----
STORAGE_BACKEND=s3                   # s3 | supabase
                                      # s3 works with AWS S3, Floci (local dev), MinIO, Cloudflare R2
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_ALLOWED_MIME_TYPES=image/png,image/jpeg,application/pdf

# ----- S3-Compatible Storage (when STORAGE_BACKEND=s3) -----
S3_ENDPOINT_URL=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=any                 # Floci ignores; use real IAM keys in prod
S3_SECRET_ACCESS_KEY=any              # Floci ignores; use real IAM keys in prod
S3_FORCE_PATH_STYLE=true             # true for Floci/MinIO/R2; false for AWS S3
S3_BUCKET_QUALIFICATIONS=qualifications
S3_PRESIGNED_URL_TTL_SECONDS=900

# ----- Notifications -----
NOTIFICATION_RETRY_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_SECONDS=60
NOTIFICATION_BATCH_SIZE=50

# ----- Rate Limiting -----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_LOGIN_PER_HOUR=50
RATE_LIMIT_VERIFY_EMAIL_PER_MINUTE=10
RATE_LIMIT_VERIFY_EMAIL_PER_HOUR=50
RATE_LIMIT_RESEND_PER_MINUTE=5
RATE_LIMIT_RESEND_PER_HOUR=20
RATE_LIMIT_ACCEPT_INVITATION_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=30

# ----- Observability -----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ----- Feature Flags -----
FEATURE_REGISTRATION_ENABLED=false   # never true in Phase 1
FEATURE_BILLING_ENABLED=false
FEATURE_2FA_ENABLED=false

# ----- Seed / Bootstrap -----
SEED_SUPER_ADMIN_EMAIL=super@qlockcare.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe!Super#2026
SEED_DEMO_AGENCY_NAME=Demo Home Care
SEED_DEMO_AGENCY_TIMEZONE=America/Chicago